# Nginx Configuration Example for TruthForge AI
# 
# This is an example configuration for running TruthForge AI behind Nginx
# with HTTPS and load balancing capabilities.
#
# Installation:
# 1. Save this as /etc/nginx/sites-available/truthforge
# 2. Create symlink: ln -s /etc/nginx/sites-available/truthforge /etc/nginx/sites-enabled/truthforge
# 3. Test: nginx -t
# 4. Reload: systemctl reload nginx

# Upstream server pool
upstream truthforge_backend {
    # Single instance
    server localhost:3000;
    
    # For multiple instances (PM2 cluster mode), add:
    # server localhost:3000;
    # server localhost:3001;
    # server localhost:3002;
    # server localhost:3003;
    
    # Connection settings
    keepalive 32;
    keepalive_requests 100;
    keepalive_timeout 60s;
}

# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name truthforge.example.com;
    
    return 301 https://$server_name$request_uri;
}

# HTTPS server
server {
    listen 443 ssl http2;
    server_name truthforge.example.com;
    
    # SSL configuration
    ssl_certificate /etc/letsencrypt/live/truthforge.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/truthforge.example.com/privkey.pem;
    
    # SSL security
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    
    # HSTS header
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    
    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-XSS-Protection "1; mode=block" always;
    
    # Logging
    access_log /var/log/nginx/truthforge_access.log;
    error_log /var/log/nginx/truthforge_error.log;
    
    # Timeouts
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    
    # Gzip compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss;
    gzip_min_length 1000;
    gzip_proxied any;
    
    # Client body limits
    client_max_body_size 10M;
    
    # Root location (proxy to backend)
    location / {
        proxy_pass http://truthforge_backend;
        
        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $server_name;
        proxy_set_header Connection "upgrade";
        proxy_set_header Upgrade $http_upgrade;
        
        # Buffering
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;
        
        # Error handling
        proxy_intercept_errors on;
    }
    
    # Health check endpoint (no logging)
    location = /health {
        proxy_pass http://truthforge_backend;
        access_log off;
        proxy_intercept_errors off;
    }
    
    # API health endpoint (no logging)
    location = /api/truthforge/health {
        proxy_pass http://truthforge_backend;
        access_log off;
        proxy_intercept_errors off;
    }
    
    # Static files (if serving frontend)
    location ~* ^/assets/ {
        proxy_pass http://truthforge_backend;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
    
    # Deny access to hidden files
    location ~ /\. {
        deny all;
    }
    
    # Deny access to backup files
    location ~ ~$ {
        deny all;
    }
    
    # Custom error pages (optional)
    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        internal;
    }
}

# Load balancing with multiple instances (advanced)
# Uncomment to use with PM2 cluster mode on multiple ports
#
# upstream truthforge_backend_cluster {
#     server localhost:3000 weight=1;
#     server localhost:3001 weight=1;
#     server localhost:3002 weight=1;
#     server localhost:3003 weight=1;
#     
#     # Least connections algorithm
#     least_conn;
#     
#     # Health check (requires ngx_http_upstream_module)
#     check interval=3000 rise=2 fall=5 timeout=1000 type=http;
#     check_http_send "GET /health HTTP/1.0\r\n\r\n";
#     check_http_expect_alive http_2xx;
# }

# Setup Instructions
# ==================
#
# 1. Install Nginx (Ubuntu/Debian):
#    sudo apt-get update && sudo apt-get install nginx certbot python3-certbot-nginx
#
# 2. Create SSL certificate (Let's Encrypt):
#    sudo certbot certonly --standalone -d truthforge.example.com
#
# 3. Place this config at /etc/nginx/sites-available/truthforge
#
# 4. Create symlink:
#    sudo ln -s /etc/nginx/sites-available/truthforge /etc/nginx/sites-enabled/truthforge
#
# 5. Test configuration:
#    sudo nginx -t
#
# 6. Reload Nginx:
#    sudo systemctl reload nginx
#
# 7. Verify:
#    curl https://truthforge.example.com/health
#
# Maintenance
# ===========
#
# View logs:
#   tail -f /var/log/nginx/truthforge_access.log
#   tail -f /var/log/nginx/truthforge_error.log
#
# Reload after config change:
#   sudo systemctl reload nginx
#
# Restart Nginx:
#   sudo systemctl restart nginx
#
# Check Nginx status:
#   sudo systemctl status nginx
